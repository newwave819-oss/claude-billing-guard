{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/billing_guard_hook.py",
            "timeout": 10,
            "statusMessage": "課金チェック中..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/billing_usage_log_hook.py",
            "timeout": 10,
            "statusMessage": "使用量を記録中..."
          }
        ]
      }
    ]
  }
}
